services:
  project-x:
    build: .
    container_name: project-x-bot
    restart: unless-stopped

    ports:
      - "8000:8000"

    volumes:
      # Sessions must persist across restarts — otherwise the bot loses its
      # WhatsApp login and needs to re-scan QR every time
      - ./sessions:/app/sessions

      # Card image cache — optional but saves re-fetching on restart
      - ./cache:/app/cache

      # cards.json / cards_restructured.json — local card fallback data
      - ./cards.json:/app/cards.json:ro
      - ./cards_restructured.json:/app/cards_restructured.json:ro

    environment:
      - NODE_OPTIONS=--max-old-space-size=512
      - PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
      - PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

    # Prevent the container from using too much system memory
    mem_limit: 1g
    memswap_limit: 1g

    # Give the bot time to connect before health checks fire
    healthcheck:
      test: ["CMD", "wget", "-qO-", "http://localhost:8000/health"]
      interval: 60s
      timeout: 10s
      retries: 3
      start_period: 40s

    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"